# Copy to `.env` (gitignored). Restart the dev server after changes.

# Dev server: webpack may need this when proxy/LAN host checks fail on Windows.
DANGEROUSLY_DISABLE_HOST_CHECK=true

# --- Create React App (public; baked into the JS bundle at build time) ---

# Your backend (Django, etc.). Used for Square checkout API calls unless overridden below.
REACT_APP_API_BASE_URL=http://127.0.0.1:8000

# Optional: payment API on a different origin than REACT_APP_API_BASE_URL (e.g. Render).
# If unset, checkout uses REACT_APP_API_BASE_URL (defaults to http://127.0.0.1:8000 in code).
# REACT_APP_PAYMENT_API_URL=

# Square Web Payments — Sandbox Application ID from Developer Dashboard (public in the browser).
REACT_APP_SQUARE_APPLICATION_ID=

# Optional: if your backend exposes a fixed Square location id for the Web Payments SDK.
# REACT_APP_SQUARE_LOCATION_ID=
