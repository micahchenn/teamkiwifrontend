# Copy to `.env` (gitignored). Restart the dev server after changes.

DANGEROUSLY_DISABLE_HOST_CHECK=true

# Backend API (no trailing slash). Production example:
# REACT_APP_API_BASE_URL=https://teamkiwibackend.onrender.com
REACT_APP_API_BASE_URL=http://127.0.0.1:8000

# Optional: payment API on another origin than REACT_APP_API_BASE_URL.
# REACT_APP_PAYMENT_API_URL=

# Square Web Payments — public Application ID from Developer Dashboard.
REACT_APP_SQUARE_APPLICATION_ID=

# Optional: fixed Square location id if your backend contract uses it in the client.
# REACT_APP_SQUARE_LOCATION_ID=
